{
  "name": "knoweia-desktop",
  "productName": "Knoweia",
  "description": "Knoweia desktop app for AI-powered tutoring and course learning.",
  "private": true,
  "version": "0.1.1",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test tests/runtimeManager.start.matrix.test.mjs",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "dev:renderer": "vite",
    "dev:electron": "node -e \"process.env.VITE_DEV_SERVER_URL='http://localhost:3000';require('child_process').execFileSync(require('electron'),['./electron/main.mjs'],{stdio:'inherit',env:{...process.env,VITE_DEV_SERVER_URL:'http://localhost:3000'}})\"",
    "dev:desktop": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:desktop:dev": "TUTOR_BACKEND_URL=http://47.93.151.131:10723 VITE_BACKEND_URL=http://47.93.151.131:10723 concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "postinstall": "node -e \"if(process.platform!=='win32'){require('child_process').execSync('chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null; chmod +x node_modules/node-pty/build/Release/spawn-helper 2>/dev/null; true',{stdio:'inherit'})}\"",
    "pack:desktop": "npm run build:renderer && npm_config_electron_mirror= electron-builder --dir",
    "build:desktop": "npm run build:renderer && npm_config_electron_mirror= electron-builder"
  },
  "build": {
    "appId": "com.knoweia.desktop",
    "productName": "Knoweia",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "assets/icon.icns",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "x64ArchFiles": "Contents/Resources/app.asar.unpacked/node_modules/node-pty/**",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@google/genai": "latest",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "0.303.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "9.0.1",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-raw": "7.0.0",
    "remark-gfm": "4.0.0",
    "tar": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "31.4.0",
    "electron-builder": "26.7.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
